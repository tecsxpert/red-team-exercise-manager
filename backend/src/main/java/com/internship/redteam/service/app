app:
  build: ./backend
  container_name: redteam-app
  ports:
    - "8080:8080"

  depends_on:
    db:
      condition: service_healthy

  environment:
    SPRING_DATASOURCE_URL: jdbc:mysql://db:3306/redteam
    SPRING_DATASOURCE_USERNAME: root
    SPRING_DATASOURCE_PASSWORD: root

  healthcheck:
    test: ["CMD", "curl", "-f", "http://localhost:8080"]
    interval: 30s
    timeout: 10s
    retries: 3